# ─────────────────────────────────────────────────────────────────────────────
# Ragnarok .gitignore — intentionally minimal.
# Only two kinds of things belong here:
#   1. Secrets / per-user config that MUST NOT reach GitHub (API keys, env).
#   2. Regenerable artifacts that are never source (deps, build output, caches).
# Nothing inside a source directory is excluded unless it is a secret/env file.
# Patterns that could collide with the code tree are anchored, so source dirs
# such as src/features/build/ and src/lib/data/ stay tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets — MUST NOT be committed ──────────────────────────────────────────
# CRA bakes REACT_APP_* into the bundle at build time, so any committed key
# ships to every browser. Per-user keys belong in the in-app Settings
# (browser localStorage), never in the repo.
.env
frontend/*/.env.local
frontend/*/.env.*.local
frontend/*/src/lib/api/secrets.local.ts
frontend/*/src/lib/api/secrets.local.json

# Local plugin-server registry (user-specific absolute paths)
plugins.env

# Installed plugins — user-specific, may embed user API keys
.ragnarok/

# ── Regenerable artifacts (never source) ─────────────────────────────────────
# JS dependencies
node_modules/

# Python virtual environments
.venv/
.venv-pypsa/
venv/

# Python bytecode + packaging output
__pycache__/
*.py[cod]
*.egg-info/

# Frontend production build — anchored to the app root, NOT src/**/build/.
# The CRA output under frontend/*/build/ stays ignored; the repo-root /build/
# is a COMMITTED deployment copy (the backend serves it, and serve.* uses it so
# npm-less machines can run the app). Refresh it with scripts/refresh_build.sh.
frontend/*/build/

# Tooling caches / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# App runtime cache
.matplotlib/

# Importer runtime cache (downloaded datasets) + root-level data dumps
backend/data/cache/
# Server-side stored runs (Store-in-backend run option)
backend/data/runs/
# Server-side working-model session + serial run queue (runtime data)
backend/data/session/
backend/data/queue/
# Installed backend plugins (3rd-party, uploaded at runtime — Ragnarok ships none)
backend/data/plugins/
# Per-plugin server-side file store (heavy model workbooks uploaded at runtime)
backend/data/plugin_files/
# Server-recorded importer API keys (credentials — never commit)
backend/data/secrets.json
# PyPSA-Earth (I9): the workflow checkout installed by scripts/setup_pypsa_earth.sh
# and the runtime override pointing Ragnarok at it — installed locally, never committed
/pypsa-earth/
backend/data/pypsa_earth.json
backend/data/pypsa_earth_run.pid
# stray clone that can land here if the setup script gets a '#' arg (escaped —
# a bare # is a gitignore comment)
/\#/
/data

# Local scratch output (sample/exported workbooks — not source)
/output/

# Logs
*.log

# OS junk
.DS_Store
**/.DS_Store
