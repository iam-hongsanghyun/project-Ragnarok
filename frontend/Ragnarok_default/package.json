{
  "name": "pypsa-gui",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://127.0.0.1:8000",
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^16.18.91",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "exceljs": "^4.4.0",
    "fflate": "^0.8.3",
    "leaflet": "^1.9.4",
    "lodash": "^4.18.1",
    "marked": "^4.3.0",
    "react": "^19.0.0",
    "react-calendar": "^5.1.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-responsive-carousel": "^3.2.23",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "uuid": "^9.0.1",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "generate:support-matrix": "node scripts/generate-support-matrix.mjs",
    "start": "REACT_APP_BUILD_ID=dev react-scripts start",
    "start:frontend": "REACT_APP_BUILD_ID=dev react-scripts start",
    "build": "REACT_APP_BUILD_ID=v$npm_package_version-$(date +%s) react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "src/lib/**/*.ts",
          "src/lib/**/*.tsx"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "react",
                    "react-dom",
                    "react-leaflet",
                    "react-calendar",
                    "react-responsive-carousel",
                    "features/*",
                    "views/*",
                    "layout/*",
                    "shared/components/*",
                    "shared/hooks/*"
                  ],
                  "message": "src/lib/ is the pure-logic layer and must not import UI / React code. Move the type to lib/ instead. (Type-only Leaflet imports are allowed for geometry type names.)"
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
