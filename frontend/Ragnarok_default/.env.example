# =============================================================================
# Ragnarok frontend — example env file
# =============================================================================
# Copy this file to `.env.local` (which IS gitignored) and fill in values for
# your dev host. CRA only injects variables prefixed with REACT_APP_ into the
# bundle (`process.env.REACT_APP_*`), so other shell vars stay invisible to
# the frontend.
#
# IMPORTANT — these values are baked into the JS bundle at build time and
# served to every visitor. They are NOT secrets in any meaningful sense; they
# are convenience defaults so a dev machine doesn't have to type a key every
# session. Never put a production key in these files.
#
# Per-user keys (e.g. an analyst's personal ENTSO-E token) live in browser
# localStorage via the Settings panel — see `src/lib/api/secrets.ts`.

# ── Upstream endpoint overrides (optional; defaults shipped in code) ────────
# Useful when you're proxying through a local cache, mirroring a dataset,
# or testing against a staging upstream.
REACT_APP_RAGNAROK_BOUNDARIES_URL=
REACT_APP_RAGNAROK_OVERPASS_URL=
REACT_APP_RAGNAROK_OVERPASS_UA=
REACT_APP_RAGNAROK_WRI_GPPD_URL=
REACT_APP_RAGNAROK_WORLDBANK_URL=

# ── API keys (dev-host fallbacks; per-user keys belong in Settings) ────────
# Tier-2 sources that gate fetches behind a token. Leave blank to require
# the user to enter their own key in the Settings panel.
REACT_APP_RAGNAROK_ENTSOE_KEY=
REACT_APP_RAGNAROK_EIA_KEY=
REACT_APP_RAGNAROK_RENEWABLES_NINJA_KEY=
REACT_APP_RAGNAROK_OPENEI_KEY=
REACT_APP_RAGNAROK_EMBER_KEY=
