{
  "id": "renewables_ninja",
  "name": "Renewables.ninja hourly profiles",
  "category": "generation",
  "subcategory": "Profiles",
  "license": "CC-BY 4.0",
  "homepage": "https://www.renewables.ninja",
  "version_hint": "v1.1 API",
  "description": "Hourly wind/solar capacity-factor time series at the selected country's centroid. Global coverage. Rate-limited; honour Retry-After.",
  "targets": ["generators", "generators-p_max_pu", "snapshots"],
  "filters": [
    {
      "id": "date_from",
      "label": "From",
      "kind": "date",
      "default": "2019-01-01",
      "min": "2014-01-01",
      "max": "2019-12-31"
    },
    {
      "id": "date_to",
      "label": "To",
      "kind": "date",
      "default": "2019-12-31",
      "min": "2014-01-01",
      "max": "2019-12-31"
    },
    {
      "id": "tech",
      "label": "Technologies",
      "kind": "multiselect",
      "default": ["wind", "solar"],
      "options": [
        { "value": "wind", "label": "Wind (onshore)" },
        { "value": "solar", "label": "Solar PV" }
      ]
    }
  ]
}
