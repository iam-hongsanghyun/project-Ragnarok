{
  "id": "pypsa_technology_data",
  "name": "PyPSA technology-data costs",
  "category": "costs",
  "subcategory": "Annual snapshots",
  "license": "CC-BY 4.0",
  "homepage": "https://github.com/PyPSA/technology-data",
  "version_hint": "master",
  "description": "Annual cost / efficiency / lifetime / CO2 intensity assumptions per technology, sourced from PyPSA/technology-data's costs_{year}.csv. This is the one place carrier rows get non-empty cost columns — every other importer leaves them empty.",
  "targets": ["carriers"],
  "filters": [
    {
      "id": "year",
      "label": "Snapshot year",
      "kind": "select",
      "default": "2030",
      "options": [
        { "value": "2020", "label": "2020" },
        { "value": "2025", "label": "2025" },
        { "value": "2030", "label": "2030" },
        { "value": "2035", "label": "2035" },
        { "value": "2040", "label": "2040" },
        { "value": "2045", "label": "2045" },
        { "value": "2050", "label": "2050" }
      ]
    }
  ]
}
