# Backend environment overrides. Copy to backend/.env and edit; every
# variable is read directly via os.environ, no python-dotenv loader. Lines
# starting with '#' are ignored.

# ── Session storage engine ──────────────────────────────────────────────────

# Working-model store backend. Default is "sqlite": one project.db per session
# (backend/data/session/<id>/project.db) — Ragnarok keeps zero scattered files,
# and any pre-flip JSON/Parquet session is migrated into its project.db on first
# read. Set to "legacy" to keep the old JSON + Parquet files (escape hatch).
# RAGNAROK_STORE=sqlite

# ── Data importer subsystem (Data view) ─────────────────────────────────────

# Where to cache the Natural Earth country boundaries GeoJSON. The file is
# downloaded once from RAGNAROK_BOUNDARIES_URL on first request.
# RAGNAROK_BOUNDARIES_PATH=/abs/path/to/countries.geojson
# RAGNAROK_BOUNDARIES_URL=https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson

# OpenStreetMap Overpass endpoint. Defaults to the public main instance;
# override for self-hosted (Kumi Systems, etc.) deployments.
# RAGNAROK_OVERPASS_URL=https://overpass-api.de/api/interpreter

# WRI Global Power Plant Database CSV URL. Public.
# RAGNAROK_WRI_GPPD_URL=
# Local CSV override (skips the HTTP fetch entirely).
# RAGNAROK_WRI_GPPD_PATH=/abs/path/to/global_power_plant_database.csv

# PyPSA-Earth release-asset manifest. Path to a JSON file with the shape
# {countries: {<ISO_A3>: {<variant>: {<release_tag>: <url>}}}}. Empty by
# default — supply your own manifest for the countries you need.
# RAGNAROK_PYPSA_EARTH_MANIFEST=/abs/path/to/manifest.json
